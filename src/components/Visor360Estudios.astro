---
// Visor360.astro
const imagenEstudio411 = "/renders/411-360(2)p-c2.webp"; 
// const imagenCocina = "/renders/360-cocina.webp";
// const imagenGym = "/renders/360-gym.webp";
// const imagenJacuzzi = "/renders/jacuzzi-360.webp";
---

<div id="panorama-wrapper" style="width: 100%; height: 100vh; position: relative; background-color: #2c2c2c;">
  <div id="panorama" style="width: 100%; height: 100%;"></div>
</div>

<style is:global>
  .flecha-animada {
    width: 50px;
    height: 50px;
    background-color: rgba(0, 0, 0, 0.2);
    border-radius: 50%;
    border: 3px solid white;
    position: relative;
    cursor: pointer;
    pointer-events: auto;
  }
  .pnlm-load-box { display: none !important; }
  .flecha-animada::after {
    content: "∧";
    color: white;
    font-family: Arial, sans-serif;
    font-size: 32px;
    font-weight: bold;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -55%);
  }
  .flecha-animada::before {
    content: "";
    position: absolute;
    top: -12px; left: -12px; right: -12px; bottom: -12px;
    border: 3px solid white;
    border-radius: 50%;
    animation: latido 1.5s infinite ease-out;
  }
  @keyframes latido {
    0%   { transform: scale(0.8); opacity: 1; }
    100% { transform: scale(1.2); opacity: 0; }
  }
  .pnlm-tooltip { display: none !important; }
</style>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/pannellum@2.5.6/build/pannellum.css"/>
<script is:inline src="https://cdn.jsdelivr.net/npm/pannellum@2.5.6/build/pannellum.js"></script>

<script define:vars={{ imagenEstudio411 }}>
  let visor = null;

  // Inyectar el menú con estilos 100% inline (no depende de clases externas)
  const crearMenu = () => {
    const escenas = [
      { id: 'estudio411', label: 'Estudio 411', icono: '🏠' },
    ];

    const wrapper = document.getElementById('panorama-wrapper');

    const menu = document.createElement('div');
    menu.id = 'menu-escenas';
    Object.assign(menu.style, {
      position: 'absolute',
      top: '20px',
      left: '50%',
      transform: 'translateX(-50%)',
      zIndex: '200',
      display: 'flex',
      gap: '6px',
      background: 'rgba(0,0,0,0.55)',
      border: '1px solid rgba(255,255,255,0.2)',
      borderRadius: '40px',
      padding: '6px 10px',
    });

    escenas.forEach(({ id, label, icono }) => {
      const btn = document.createElement('button');
      btn.dataset.escena = id;
      btn.innerHTML = `<span style="font-size:14px">${icono}</span> ${label}`;

      const estilosBase = {
        background: 'transparent',
        border: '1px solid rgba(255,255,255,0.35)',
        color: 'rgba(255,255,255,0.85)',
        borderRadius: '30px',
        padding: '6px 16px',
        fontSize: '13px',
        fontFamily: 'system-ui, sans-serif',
        cursor: 'pointer',
        display: 'flex',
        alignItems: 'center',
        gap: '6px',
        whiteSpace: 'nowrap',
        transition: 'background 0.2s, color 0.2s',
      };

      Object.assign(btn.style, estilosBase);

      btn.addEventListener('mouseenter', () => {
        if (!btn.classList.contains('activo')) {
          btn.style.background = 'rgba(255,255,255,0.15)';
          btn.style.color = '#fff';
        }
      });
      btn.addEventListener('mouseleave', () => {
        if (!btn.classList.contains('activo')) {
          btn.style.background = 'transparent';
          btn.style.color = 'rgba(255,255,255,0.85)';
        }
      });

      btn.addEventListener('click', () => {
        if (visor) {
          visor.loadScene(id);
          actualizarMenuActivo(id);
        }
      });

      menu.appendChild(btn);
    });

    wrapper.appendChild(menu);

    // Activar el primero por defecto
    actualizarMenuActivo('estudio411');
  };

  const actualizarMenuActivo = (escenaId) => {
    document.querySelectorAll('#menu-escenas button').forEach(btn => {
      const esActivo = btn.dataset.escena === escenaId;
      btn.classList.toggle('activo', esActivo);
      Object.assign(btn.style, esActivo
        ? { background: 'rgba(255,255,255,0.92)', color: '#1a1a1a', border: '1px solid transparent', fontWeight: '600' }
        : { background: 'transparent', color: 'rgba(255,255,255,0.85)', border: '1px solid rgba(255,255,255,0.35)', fontWeight: '400' }
      );
    });
  };

  const iniciarVisor = () => {
    if (document.getElementById('panorama') && typeof pannellum !== 'undefined') {

      crearMenu();

      visor = pannellum.viewer('panorama', {
        "default": {
          "firstScene": "estudio411",
          "sceneFadeDuration": 1000,
          "autoLoad": true,
          "showControls": true,
          "autoRotate": 0
        },
        "scenes": {
          "estudio411": {
            "type": "equirectangular",
            "panorama": imagenEstudio411,
            "hotSpots": [
              // { "pitch": 0, "yaw": 260, "type": "scene", "sceneId": "sala",  "cssClass": "flecha-animada" },
              // { "pitch": 0, "yaw": -20, "type": "scene", "sceneId": "gym",   "cssClass": "flecha-animada" }
            ]
          },
          // "sala": {
          //   "type": "equirectangular",
          //   "panorama": imagenSala,
          //   "hotSpots": [
          //     { "pitch": 0, "yaw": 15,  "type": "scene", "sceneId": "jacuzzi", "cssClass": "flecha-animada" },
          //     { "pitch": 0, "yaw": 110, "type": "scene", "sceneId": "cocina",  "cssClass": "flecha-animada" }
          //   ]
          // },
          // "gym": {
          //   "type": "equirectangular",
          //   "panorama": imagenGym,
          //   "hotSpots": [
          //     { "pitch": 0, "yaw": -30, "type": "scene", "sceneId": "cocina",  "cssClass": "flecha-animada" },
          //     { "pitch": 0, "yaw": 100, "type": "scene", "sceneId": "jacuzzi", "cssClass": "flecha-animada" }
          //   ]
          // },
          // "jacuzzi": {
          //   "type": "equirectangular",
          //   "panorama": imagenJacuzzi,
          //   "hotSpots": [
          //     { "pitch": 0, "yaw": -50, "type": "scene", "sceneId": "sala", "cssClass": "flecha-animada" },
          //     { "pitch": 0, "yaw": 230, "type": "scene", "sceneId": "gym",  "cssClass": "flecha-animada" }
          //   ]
          // }
        }
      });

      // Sincronizar menú cuando se navega con hotspots
      visor.on('scenechange', (escenaId) => {
        actualizarMenuActivo(escenaId);
      });

    } else {
      setTimeout(iniciarVisor, 50);
    }
  };

  iniciarVisor();
</script>