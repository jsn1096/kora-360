---
// Definimos las rutas de los renders
const imagenes = {
  cocina: "/renders/360-cocina.webp",
  sala: "/renders/360-sala.webp",
  gym: "/renders/360-gym.webp",
  jacuzzi: "/renders/jacuzzi-360.webp"
};
---

<script src="https://aframe.io/releases/1.6.0/aframe.min.js"></script>

<div class="contenedor-vr">
  <a-scene embedded xr-mode-ui="enabled: true">
    <a-assets>
      {Object.entries(imagenes).map(([id, url]) => (
        <img id={id} src={url} crossorigin="anonymous" />
      ))}
    </a-assets>

    <a-sky id="sky-master" src="#cocina" rotation="0 -90 0"></a-sky>

    <a-entity camera look-controls>
      <a-cursor
        id="cursor"
        animation__click="property: scale; startEvents: click; easing: easeInCubic; dur: 150; from: 0.1 0.1 0.1; to: 1 1 1"
        animation__fusing="property: scale; startEvents: fusing; easing: easeInCubic; dur: 1500; from: 1 1 1; to: 0.1 0.1 0.1"
        event-set__mouseenter="_event: mouseenter; color: #00ff00"
        event-set__mouseleave="_event: mouseleave; color: black"
        raycaster="objects: .clickable">
      </a-cursor>
    </a-entity>

    <a-entity id="hotspots-container"></a-entity>
  </a-scene>
</div>

<style>
  .contenedor-vr {
    width: 100%;
    height: 100vh;
    background: #000;
  }
  /* A-Frame maneja su propia interfaz, pero puedes añadir estilos aquí si necesitas */
</style>

<script is:inline>
  // Configuración de las conexiones entre escenas (tu lógica original)
  const escenas = {
    cocina: [
      { pos: {x: -4, y: 0, z: -2}, destino: "sala", label: "Ir a Sala" },
      { pos: {x: 4, y: 0, z: -1}, destino: "gym", label: "Ir al Gym" }
    ],
    sala: [
      { pos: {x: 2, y: 0, z: -4}, destino: "jacuzzi", label: "Ir al Jacuzzi" },
      { pos: {x: -3, y: 0, z: 2}, destino: "cocina", label: "Volver a Cocina" }
    ],
    // Añadir el resto de conexiones aquí...
  };

  const sky = document.querySelector('#sky-master');
  const container = document.querySelector('#hotspots-container');

  function cargarEscena(nombreEscena) {
    // 1. Cambiar la imagen del fondo
    sky.setAttribute('src', `#${nombreEscena}`);

    // 2. Limpiar hotspots anteriores
    container.innerHTML = '';

    // 3. Crear nuevos hotspots
    const puntos = escenas[nombreEscena] || [];
    puntos.forEach(punto => {
      const el = document.createElement('a-entity');
      
      // Geometría del hotspot (puedes usar un plano con tu flecha o un círculo)
      el.setAttribute('geometry', 'primitive: circle; radius: 0.3');
      el.setAttribute('material', 'color: white; side: double; opacity: 0.8');
      el.setAttribute('position', punto.pos);
      el.setAttribute('class', 'clickable');
      
      // Orientación para que siempre mire a la cámara (billboard)
      el.setAttribute('look-at', '[camera]');

      // Evento de clic
      el.addEventListener('click', () => {
        console.log("Cambiando a:", punto.destino);
        cargarEscena(punto.destino);
      });

      container.appendChild(el);
    });
  }

  // Iniciar en la cocina
  window.addEventListener('load', () => cargarEscena('cocina'));
</script>