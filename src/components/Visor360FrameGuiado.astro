---
const imagenes = {
  cocina: "/renders/360-cocina.webp",
  sala: "/renders/360-sala.webp",
  gym: "/renders/360-gym.webp",
  jacuzzi: "/renders/jacuzzi-360.webp",
  estudio411: "/renders/411-360.webp",
  departamento610: "/renders/610-360.webp",
  cuarto1610: "/renders/cuarto1-360.webp",
  cuarto2610: "/renders/cuarto2-360.webp",
  estudio404: "/renders/404-360.webp",
  contentarea: "/renders/360-contentarea.webp",
  entrada: "/renders/test-5.png",
  lobby: "/renders/360-lobby.webp",
  coworking: "/renders/360-coworking.webp",
};

const secciones = [
  { id: "terraza", label: "Terraza", emoji: "☀️", href: "/terraza" },
  { id: "suites", label: "Suites", emoji: "🛏️", href: "/suites" },
  { id: "areas-sociales", label: "Áreas Sociales", emoji: "🏊️", href: "/areas-sociales" },
];
---

<script src="https://aframe.io/releases/1.6.0/aframe.min.js"></script>
<script src="https://unpkg.com/aframe-event-set-component@5.0.0/dist/aframe-event-set-component.min.js"></script>
<script src="https://unpkg.com/aframe-look-at-component@0.8.0/dist/aframe-look-at-component.min.js"></script>

<nav id="menu-nav">
  <button id="btn-menu" aria-label="Abrir menú">
    <span class="hamburger"></span>
    <span class="hamburger"></span>
    <span class="hamburger"></span>
  </button>

  <div id="menu-panel" class="cerrado">
    <p class="menu-titulo">Explorar</p>

    {secciones.map((s) => (
      <a href={s.href} class="menu-item" data-id={s.id}>
        <span class="menu-emoji">{s.emoji}</span>
        <span class="menu-label">{s.label}</span>
      </a>
    ))}

    <!-- BOTONES DEMO -->
    <button onclick="window.mostrarVideo()" class="menu-video-btn">
      🎬 Ver Video
    </button>

    <button onclick="window.mostrarPanorama('entrada')" class="menu-video-btn">
      🌎 Volver Panorama
    </button>
  </div>
</nav>

<div class="contenedor-vr">
  <a-scene
    embedded
    xr-mode-ui="enabled: true"
    renderer="
      antialias: true;
      colorManagement: true;
      physicallyCorrectLights: true;
      highRefreshRate: true;
      precision: high;
    "
  >
    <a-assets>

      {Object.entries(imagenes).map(([id, url]) => (
        <img id={id} src={url} crossorigin="anonymous" />
      ))}

      <!-- VIDEO -->
      <video
        id="video-demo"
        src="/videos/KORA-CONCEPTO.mp4"
        loop
        muted
        crossorigin="anonymous"
        playsinline
        webkit-playsinline
        preload="auto"
      ></video>

    </a-assets>

    <!-- VIDEO CURVO -->
    <a-curvedimage
      id="pantalla-video"
      src="#video-demo"
      radius="8"
      theta-length="120"
      height="5"
      position="0 2 -1"
      visible="false"
    ></a-curvedimage>

    <!-- LUCES -->
    <a-light type="ambient" intensity="0.2"></a-light>

    <a-light
      type="point"
      intensity="0.5"
      position="0 3 -4"
    ></a-light>

    <!-- CAMARA -->
    <a-entity
      id="camera"
      position="0 1.6 0"
      camera="fov: 70"
      look-controls
    ></a-entity>

  </a-scene>
</div>

<style>
  .contenedor-vr {
    width: 100%;
    height: 100vh;
    background: #000;
  }

  #menu-nav {
    position: fixed;
    top: 20px;
    left: 20px;
    z-index: 9999;
    font-family: 'Segoe UI', sans-serif;
  }

  #btn-menu {
    display: flex;
    flex-direction: column;
    gap: 5px;
    background: rgba(0,0,0,0.6);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 10px;
    padding: 12px;
    cursor: pointer;
    backdrop-filter: blur(10px);
  }

  .hamburger {
    display: block;
    width: 22px;
    height: 2px;
    background: white;
    border-radius: 2px;
  }

  #menu-panel {
    position: absolute;
    top: calc(100% + 10px);
    left: 0;
    background: rgba(0,0,0,0.75);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 14px;
    padding: 12px;
    min-width: 220px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    transform-origin: top left;
    transition: opacity 0.2s, transform 0.2s;
  }

  #menu-panel.cerrado {
    opacity: 0;
    pointer-events: none;
    transform: scale(0.95);
  }

  #menu-panel.abierto {
    opacity: 1;
    pointer-events: all;
    transform: scale(1);
  }

  .menu-titulo {
    color: rgba(255,255,255,0.4);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin: 0 0 4px 8px;
  }

  .menu-item,
  .menu-video-btn {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    border-radius: 10px;
    color: white;
    text-decoration: none;
    font-size: 15px;
    transition: background 0.15s;
    background: transparent;
    border: none;
    cursor: pointer;
    width: 100%;
    text-align: left;
  }

  .menu-item:hover,
  .menu-video-btn:hover {
    background: rgba(255,255,255,0.1);
  }

  .menu-item.activo {
    background: rgba(255,255,255,0.15);
    font-weight: 600;
  }

  .menu-emoji {
    font-size: 18px;
    width: 24px;
    text-align: center;
  }

  .menu-label {
    flex: 1;
  }
</style>

<script is:inline>

  // MOSTRAR VIDEO
  window.mostrarVideo = async function() {

    const pantalla = document.getElementById('pantalla-video');

    pantalla.setAttribute('visible', true);

    const video = document.getElementById('video-demo');

    try {
      await video.play();
    } catch (err) {
      console.error(err);
    }

    const sceneEl = document.querySelector('a-scene');

    sceneEl.object3D.background = new THREE.Color(0x000000);

    const cielo = document.querySelector('.cielo-dinamico');

    if (cielo) {
      cielo.setAttribute('visible', false);
    }

  }

  // VOLVER PANORAMA
  window.mostrarPanorama = function(nombreEscena) {

    const pantalla = document.getElementById('pantalla-video');

    pantalla.setAttribute('visible', false);

    const video = document.getElementById('video-demo');

    video.pause();

    const cielo = document.querySelector('.cielo-dinamico');

    if (cielo) {
      cielo.setAttribute('visible', true);
    }

    window.cargarEscena(nombreEscena);

  }

  // CARGAR PANORAMA
  window.cargarEscena = function(nombreEscena) {

    const scene = document.querySelector('a-scene');

    if (!scene) return;

    const cieloViejo = document.querySelector('.cielo-dinamico');

    if (cieloViejo) {
      cieloViejo.parentNode.removeChild(cieloViejo);
    }

    const cieloNuevo = document.createElement('a-sky');

    cieloNuevo.setAttribute('class', 'cielo-dinamico');

    cieloNuevo.setAttribute('src', `#${nombreEscena}`);

    cieloNuevo.setAttribute('rotation', '0 -90 0');

    cieloNuevo.setAttribute('material', 'shader: flat');

    scene.appendChild(cieloNuevo);

    cieloNuevo.addEventListener('loaded', () => {

      const texture = cieloNuevo.getObject3D('mesh').material.map;

      const renderer = scene.renderer;

      const maxAnisotropy =
        renderer.capabilities.getMaxAnisotropy();

      texture.anisotropy = maxAnisotropy;

      texture.needsUpdate = true;

    });

  }

  document.addEventListener('DOMContentLoaded', () => {

    // MENU
    const btnMenu = document.getElementById('btn-menu');

    const panel = document.getElementById('menu-panel');

    btnMenu.addEventListener('click', () => {

      const abierto = panel.classList.toggle('abierto');

      panel.classList.toggle('cerrado', !abierto);

    });

    document.addEventListener('click', (e) => {

      if (
        !btnMenu.contains(e.target) &&
        !panel.contains(e.target)
      ) {

        panel.classList.remove('abierto');

        panel.classList.add('cerrado');

      }

    });

    // MENU ACTIVO
    const rutaActual =
      window.location.pathname.replace('/', '');

    document.querySelectorAll('.menu-item')
      .forEach(item => {

        if (
          item.dataset.id === rutaActual ||
          (
            rutaActual === '' &&
            item.dataset.id === 'areas-sociales'
          )
        ) {

          item.classList.add('activo');

        }

      });

    // CARGA ESCENA
    const scene = document.querySelector('a-scene');

    if (scene.hasLoaded) {

      AFRAME.scenes[0]
        .renderer
        .setPixelRatio(window.devicePixelRatio);

      window.cargarEscena('entrada');

    } else {

      scene.addEventListener('loaded', () => {

        AFRAME.scenes[0]
          .renderer
          .setPixelRatio(window.devicePixelRatio);

        window.cargarEscena('entrada');

      });

    }

  });

</script>

<script>
  import PartySocket from "partysocket";

  const seccionActual = "terraza";

  const socket = new PartySocket({
    host: "tu-proyecto.jsn1096.partykit.dev",
    room: "sala-demo",
  });

  socket.addEventListener("message", (e) => {

    const data = JSON.parse(e.data);

    if (data.type === "cambiar-escena") {

      window.cargarEscena?.(data.escena);

    }

  });
</script>