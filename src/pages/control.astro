---
// src/pages/control.astro
const secciones = [
  {
    id: "terraza",
    label: "Terraza",
    emoji: "☀️",
    escenas: ["cocina", "sala", "gym", "jacuzzi"],
    videos: []
  },
  {
    id: "suites",
    label: "Suites",
    emoji: "🛏️",
    escenas: ["estudio411", "departamento610", "cuarto1610", "cuarto2610", "estudio404"],
    videos: []
  },
  {
    id: "areas-sociales",
    label: "Áreas Sociales",
    emoji: "🏊️",
    escenas: ["contentarea", "entrada", "lobby", "coworking", "tour_lobby"],
    videos: ["tour_lobby"]
  },
];
---

<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Control — Panel</title>
</head>
<body>

<div id="app">
  <header>
    <h1>🎮 Panel de Control</h1>
    <div id="estado-conexion" class="dot desconectado"></div>
  </header>

  <div id="secciones">
{secciones.map(sec => (
  <div class="seccion">
    <h2>{sec.emoji} {sec.label}</h2>

    <div class="escenas">
      {sec.escenas.map(escena => (
        <button class="btn-escena" data-escena={escena} data-tipo="escena" data-seccion={sec.id}>
          {escena}
        </button>
      ))}

      {/* 👇 Botones de video con icono distintivo */}
      {sec.videos.map(video => (
        <button class="btn-escena btn-video" data-escena={video} data-tipo="video" data-seccion={sec.id}>
          🎬 {video}
        </button>
      ))}
    </div>
  </div>
))}
  </div>

  <div id="actual">
    <p>Mostrando ahora:</p>
    <strong id="escena-actual">—</strong>
  </div>
</div>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: #0f0f0f;
    color: white;
    font-family: 'Segoe UI', sans-serif;
    min-height: 100vh;
    padding: 20px;
  }

  header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 32px;
  }

  h1 { font-size: 22px; }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .dot.conectado    { background: #10B981; box-shadow: 0 0 8px #10B981; }
  .dot.desconectado { background: #EF4444; }

  #secciones {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .seccion h2 {
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: rgba(255,255,255,0.4);
    margin-bottom: 12px;
  }

  .escenas {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .btn-escena {
    padding: 14px 20px;
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.15);
    background: rgba(255,255,255,0.07);
    color: white;
    font-size: 15px;
    cursor: pointer;
    text-transform: capitalize;
    transition: all 0.15s;
  }

  .btn-escena:hover  { background: rgba(255,255,255,0.15); }

  .btn-escena.activo {
    background: #6366F1;
    border-color: #6366F1;
    font-weight: 700;
  }

  .btn-video {
  border-color: rgba(251, 191, 36, 0.4);  /* amarillo sutil */
  color: #FCD34D;
}

.btn-video:hover {
  background: rgba(251, 191, 36, 0.15);
}

.btn-video.activo {
  background: #D97706;
  border-color: #D97706;
  color: white;
}

  #actual {
    margin-top: 40px;
    padding: 20px;
    border-radius: 14px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    text-align: center;
  }

  #actual p  { color: rgba(255,255,255,0.4); font-size: 12px; margin-bottom: 6px; }
  #actual strong { font-size: 22px; text-transform: capitalize; }
</style>

<script>
  import PartySocket from "partysocket";

  const socket = new PartySocket({
    host: "tu-proyecto.jsn1096.partykit.dev",
    room: "sala-demo",
  });

  const dotEstado    = document.getElementById("estado-conexion") as HTMLElement;
  const escenaActual = document.getElementById("escena-actual") as HTMLElement;

  socket.addEventListener("open", () => {
    dotEstado.className = "dot conectado";
  });

  socket.addEventListener("close", () => {
    dotEstado.className = "dot desconectado";
  });

// Escuchar mensajes entrantes (ambos tipos)
socket.addEventListener("message", (e) => {
  const data = JSON.parse(e.data);

  if (data.type === "cambiar-escena" || data.type === "cambiar-video") {
    const icono = data.type === "cambiar-video" ? "🎬 " : "";
    escenaActual.textContent = icono + data.escena;

    document.querySelectorAll(".btn-escena").forEach((btn) => {
      const el = btn as HTMLElement;
      el.classList.toggle("activo", el.dataset.escena === data.escena);
    });
  }
});

// Enviar al hacer click — detecta tipo automáticamente
document.querySelectorAll(".btn-escena").forEach((btn) => {
  btn.addEventListener("click", () => {
    const el = btn as HTMLElement;
    const tipo = el.dataset.tipo; // "escena" o "video"

    socket.send(JSON.stringify({
      type: tipo === "video" ? "cambiar-video" : "cambiar-escena",
      escena: el.dataset.escena,   // reutilizamos el mismo campo
      seccion: el.dataset.seccion,
    }));
  });
});
</script>

</body>
</html>